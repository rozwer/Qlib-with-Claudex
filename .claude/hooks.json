{
  "hooks": {
    "pre-tool": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash \"$(git rev-parse --show-toplevel)/.claude/hooks/guard-pkg-manager.sh\""
          },
          {
            "type": "command",
            "command": "cat | bash \"$(git rev-parse --show-toplevel)/.claude/hooks/guard-macos-multiprocessing.sh\""
          },
          {
            "type": "command",
            "command": "cat | bash \"$(git rev-parse --show-toplevel)/.claude/hooks/guard-venv-activation.sh\""
          },
          {
            "type": "command",
            "command": "cat | bash \"$(git rev-parse --show-toplevel)/.claude/hooks/guard-source-data.sh\""
          }
        ]
      }
    ],
    "post-tool": []
  }
}
